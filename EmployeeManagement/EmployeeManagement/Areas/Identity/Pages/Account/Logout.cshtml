@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Employee Management System - Logout</title>

    <!-- Google Font -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/fontawesome-free/css/all.min.css">
    <!-- Bootstrap 4 -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/bootstrap/css/bootstrap.min.css">
    <!-- Boxicons -->
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <!-- Custom Styles -->
    <link rel="stylesheet" href="~/css/customstyle.css" />
</head>
<body class="login-page">
    <div class="login-box">
        <div class="card login-card">
            <div class="login-header">
                <div class="logo-icon">
                    <i class='bx bxs-briefcase'></i>
                </div>
                <h1>EMS</h1>
                <p>Employee Management System</p>
            </div>
            <div class="login-body text-center">
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <div class="mb-4">
                        <i class='bx bx-log-out' style="font-size: 60px; color: #667eea;"></i>
                    </div>
                    <div class="login-title">Log Out</div>
                    <p class="text-muted mb-4">Are you sure you want to log out?</p>
                    
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                        <button type="submit" class="btn btn-login">
                            <i class='bx bx-check mr-2'></i>Yes, Logout
                        </button>
                    </form>
                    <div class="login-links mt-3">
                        <a href="/"><i class='bx bx-x mr-1'></i>Cancel</a>
                    </div>
                }
                else
                {
                    <div class="mb-4">
                        <i class='bx bx-check-circle' style="font-size: 60px; color: #10b981;"></i>
                    </div>
                    <div class="login-title">Logged Out!</div>
                    <p class="text-muted mb-4">You have successfully logged out.</p>
                    
                    <a asp-page="./Login" class="btn btn-login">
                        <i class='bx bx-log-in mr-2'></i>Log In Again
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- jQuery -->
    <script src="~/AdminLTE/plugins/jquery/jquery.min.js"></script>
    <!-- Bootstrap 4 -->
    <script src="~/AdminLTE/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
