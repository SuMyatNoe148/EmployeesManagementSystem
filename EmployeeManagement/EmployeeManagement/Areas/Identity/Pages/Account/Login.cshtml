@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Employee Management System - Login</title>

    <!-- Google Font -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/fontawesome-free/css/all.min.css">
    <!-- Bootstrap 4 -->
    <link rel="stylesheet" href="~/AdminLTE/plugins/bootstrap/css/bootstrap.min.css">
    <!-- Boxicons -->
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <!-- Custom Styles -->
    <link rel="stylesheet" href="~/css/customstyle.css" />
    
</head>
<body class="login-page">
    <div class="login-box">
        <div class="card login-card">
            <div class="login-header">
                <div class="logo-icon">
                    <i class='bx bxs-briefcase'></i>
                </div>
                <h1>EMS</h1>
                <p>Employee Management System</p>
            </div>
            <div class="login-body">
                <div class="login-title">Welcome Back!</div>

                <form id="account" method="post">
                    <!-- Error Toast -->
                    <div id="errorToast" class="error-toast" style="display: none;">
                        <div class="error-toast-content">
                            <i class='bx bx-error-circle error-icon'></i>
                            <div class="error-message" id="errorMessage"></div>
                            <i class='bx bx-x error-close' onclick="hideError()"></i>
                        </div>
                    </div>
                    
                    <!-- Validation Summary (hidden, used for server-side errors) -->
                    <div asp-validation-summary="All" class="text-danger" style="display:none;" data-valmsg-summary="true"></div>
                    
                    <div class="input-group-login">
                        <i class='bx bx-envelope input-icon'></i>
                        <input type="email" asp-for="Input.Email" id="emailInput" class="form-control form-control-login" autocomplete="username" aria-required="true" placeholder="Email Address" />
                    </div>
                    
                    <div class="input-group-login">
                        <i class='bx bx-lock-alt input-icon'></i>
                        <input type="password" asp-for="Input.Password" id="passwordInput" class="form-control form-control-login" autocomplete="current-password" aria-required="true" placeholder="Password"/>
                        <i class='bx bx-show password-toggle' id="togglePassword" onclick="togglePassword('passwordInput', 'togglePassword')"></i>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <label class="remember-me">
                            <input type="checkbox" asp-for="Input.RememberMe" />
                            <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                        </label>
                    </div>
                    <br />
                    <button type="submit" class="btn btn-login">
                        <i class='bx bx-log-in mr-2'></i>Sign In
                    </button>
                </form>
                
                <div class="login-links">
                    <a id="forgot-password" asp-page="./ForgotPassword"><i class='bx bx-key mr-1'></i>Forgot password?</a>
                    <span class="divider">|</span>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"><i class='bx bx-user-plus mr-1'></i>Register</a>
                </div>
            </div>
        </div>
    </div>

    <!-- jQuery -->
    <script src="~/AdminLTE/plugins/jquery/jquery.min.js"></script>
    <!-- Bootstrap 4 -->
    <script src="~/AdminLTE/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        function togglePassword(inputId, toggleId) {
            var passwordInput = document.getElementById(inputId);
            var toggleIcon = document.getElementById(toggleId);
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('bx-show');
                toggleIcon.classList.add('bx-hide');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('bx-hide');
                toggleIcon.classList.add('bx-show');
            }
        }

        function showError(message) {
            var errorToast = document.getElementById('errorToast');
            var errorMessage = document.getElementById('errorMessage');
            errorMessage.textContent = message;
            errorToast.style.display = 'block';
        }

        function hideError() {
            document.getElementById('errorToast').style.display = 'none';
        }

        // Form submission validation
        document.getElementById('account').addEventListener('submit', function(e) {
            var email = document.getElementById('emailInput').value;
            var password = document.getElementById('passwordInput').value;
            
            if (!email) {
                e.preventDefault();
                showError('Please enter your email address');
                return;
            }
            
            if (!password) {
                e.preventDefault();
                showError('Please enter your password');
                return;
            }
        });

        // Show server-side errors
        document.addEventListener('DOMContentLoaded', function() {
            var serverErrors = document.querySelectorAll('[data-valmsg-summary] ul li');
            if (serverErrors.length > 0) {
                var errorText = serverErrors[0].textContent;
                if (errorText) {
                    showError(errorText);
                }
            }
        });
    </script>
</body>
</html>


