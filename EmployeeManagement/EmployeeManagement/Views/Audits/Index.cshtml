@model IEnumerable<EmployeeManagement.Models.Audit>

@{
    ViewData["Title"] = "System Audit Logs";
    var totalCount = Model?.Count() ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-weight: 600; color: #2d3748;">
            <i class="bx bx-history mr-2" style="color: #667eea;"></i>System Audit Logs
        </h2>
        <p class="text-muted mb-0">Track system activities and changes</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-lg-4 col-md-6 mb-3">
        <div class="card stats-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1" style="opacity: 0.9; font-size: 14px;">Total Audit Records</p>
                        <h3 class="mb-0" style="font-size: 32px; font-weight: 700;">@totalCount</h3>
                    </div>
                    <div style="background: rgba(255,255,255,0.2); width: 60px; height: 60px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                        <i class="bx bx-history" style="font-size: 28px;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card main-card">
    <div class="card-body p-0">
        <div class="p-4 border-bottom" style="background: #fafbfc;">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="input-group">
                        <div class="input-group-prepend"><span class="input-group-text bg-white border-right-0" style="border-radius: 10px 0 0 10px;"><i class="bx bx-search text-muted"></i></span></div>
                        <input type="text" id="searchBox" class="form-control border-left-0 search-box" placeholder="Search by user, action or table..." style="border-radius: 0 10px 10px 0;">
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table id="dataTable" class="table table-hover mb-0" style="font-size: 14px;">
                <thead class="table-header">
                    <tr>
                        <th style="width: 60px;"></th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Table</th>
                        <th>Date & Time</th>
                        <th class="text-center" style="width: 80px;">View</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.Any() != true)
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <div style="width: 80px; height: 80px; background: #f3f4f6; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;"><i class="bx bx-history" style="font-size: 36px; color: #9ca3af;"></i></div>
                                    <h5 class="text-muted mb-2">No Audit Records Found</h5>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            var bgColors = new[] { "#667eea", "#764ba2", "#11998e", "#38ef7d", "#f093fb", "#f5576c" };
                            var bgColor = bgColors[Math.Abs(item.Id.GetHashCode()) % bgColors.Length];
                            <tr class="data-row">
                                <td class="text-center"><div class="audit-icon" style="background: @bgColor;"><i class="bx bx-history"></i></div></td>
                                <td><span style="font-weight: 600; color: #2d3748;">@item.User?.FullName</span></td>
                                <td><span class="audit-badge">@item.AuditType</span></td>
                                <td><span class="table-badge">@item.TableName</span></td>
                                <td><span class="text-muted"><i class="bx bx-time mr-1"></i>@item.DateTime.ToString("yyyy-MM-dd HH:mm")</span></td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary action-btn" data-toggle="tooltip" title="View Details"><i class="bx bx-show"></i></a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (totalCount > 0)
        {
            <div class="p-3 border-top" style="background: #fafbfc;"><small class="text-muted">Showing <strong>@totalCount</strong> record@(totalCount != 1 ? "s" : "")</small></div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('[data-toggle="tooltip"]').tooltip();
            $('#searchBox').on('keyup', function() {
                var value = $(this).val().toLowerCase();
                $('.data-row').filter(function() { $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1) });
            });
        });
    </script>
}


