@model EmployeeManagement.Models.LeaveAdjustmentEntry

@{
    ViewData["Title"] = "Leave Adjustment Entry";
}
<div class="row">
    <div class="col-xl-12 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Add New Leave Adjustment Entry</h5>
                    </div>
                    <hr />
                    <div class="row g-3">
                        <div class="col-md-12">
                            <form asp-action="Create">
                                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                <div class="row g-3">
                                    <div class="form-group col-md-6">
                                        <label asp-for="LeavePeriodId" class="control-label"></label>
                                        <select asp-for="LeavePeriodId" class="form-control" asp-items="ViewBag.LeavePeriodId">
                                        </select>
                                        <span asp-validation-for="LeavePeriodId" class="text-danger"></span>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <label asp-for="EmployeeId" class="control-label"></label>
                                        <select asp-for="EmployeeId" class="form-control" asp-items="ViewBag.EmployeeId"></select>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <label asp-for="NoOfDays" class="control-label"></label>
                                        <input asp-for="NoOfDays" class="form-control" />
                                        <span asp-validation-for="NoOfDays" class="text-danger"></span>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <label asp-for="LeaveAdjustmentDate" class="control-label"></label>
                                        <input asp-for="LeaveAdjustmentDate" class="form-control" />
                                        <span asp-validation-for="LeaveAdjustmentDate" class="text-danger"></span>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <label asp-for="LeaveStartDate" class="control-label"></label>
                                        <input asp-for="LeaveStartDate" class="form-control" />
                                        <span asp-validation-for="LeaveStartDate" class="text-danger"></span>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <label asp-for="LeaveEndDate" class="control-label"></label>
                                        <input asp-for="LeaveEndDate" class="form-control" />
                                        <span asp-validation-for="LeaveEndDate" class="text-danger"></span>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <label asp-for="AdjustmentDescription" class="control-label"></label>
                                        <input asp-for="AdjustmentDescription" class="form-control" />
                                        <span asp-validation-for="AdjustmentDescription" class="text-danger"></span>
                                    </div>
                                    <div class="form-group col-md-6">
                                        <label asp-for="AdjustmentTypeId" class="control-label"></label>
                                        <select asp-for="AdjustmentTypeId" class="form-control" asp-items="ViewBag.AdjustmentTypeId"></select>
                                    </div>
                                </div>
                                <div class="form-group p-lg-5">
                                    <div class="col-md-12">
                                        <a asp-action="Index" class="btn btn-warning float-left"><i class="bi bi-skip-backward-fill"></i> Back To List</a>
                                        <button type="submit" class="btn btn-primary float-right"><i class="bi bi-save"></i> Register Leave Adjustment Entry</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

