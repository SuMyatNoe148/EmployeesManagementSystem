@model EmployeeManagement.Models.LeaveAdjustmentEntry

@{
    ViewData["Title"] = "Delete";
}
<div class="row">
    <div class="col-xl-12 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Are you sure you want to delete this?</h5>
                    </div>
                    <hr />
                    <div class="row g-3">
                        <div class="col-md-12">
                            <table class="table table-bordered table-striped">
                                <tr>
                                    <th class="col-sm-4">
                                        @Html.DisplayNameFor(model => model.LeavePeriod)
                                    </th>
                                    <td class="col-sm-4">
                                        @Html.DisplayFor(model => model.LeavePeriod)
                                    </td>
                                    <th class="col-sm-4">
                                        @Html.DisplayNameFor(model => model.Employee)
                                    </th>
                                    <td class="col-sm-4">
                                        @Html.DisplayFor(model => model.Employee.Id)
                                    </td>
                                </tr>
                                <tr>
                                    <th class="col-sm-4">
                                        @Html.DisplayNameFor(model => model.NoOfDays)
                                    </th>
                                    <td class="col-sm-4">
                                        @Html.DisplayFor(model => model.NoOfDays)
                                    </td>
                                    <th class="col-sm-4">
                                        @Html.DisplayNameFor(model => model.LeaveAdjustmentDate)
                                    </th>
                                    <td class="col-sm-4">
                                        @Html.DisplayFor(model => model.LeaveAdjustmentDate)
                                    </td>
                                </tr>
                                <tr>
                                    <th class="col-sm-4">
                                        @Html.DisplayNameFor(model => model.LeaveStartDate)
                                    </th>
                                    <td class="col-sm-4">
                                        @Html.DisplayFor(model => model.LeaveStartDate)
                                    </td>
                                    <th class="col-sm-4">
                                        @Html.DisplayNameFor(model => model.LeaveEndDate)
                                    </th>
                                    <td class="col-sm-4">
                                        @Html.DisplayFor(model => model.LeaveEndDate)
                                    </td>
                                </tr>
                                <tr>
                                    <th class="col-sm-4">
                                        @Html.DisplayNameFor(model => model.AdjustmentDescription)
                                    </th>
                                    <td class="col-sm-4">
                                        @Html.DisplayFor(model => model.AdjustmentDescription)
                                    </td>
                                    <th class="col-sm-4">
                                        @Html.DisplayNameFor(model => model.AdjustmentType)
                                    </th>
                                    <td class="col-sm-4">
                                        @Html.DisplayFor(model => model.AdjustmentType.Id)
                                    </td>
                                </tr>
                            </table>

                            <form asp-action="Delete">
                                <input type="hidden" asp-for="Id" />
                                <input type="submit" value="Delete" class="btn btn-danger" /> |
                                <a asp-action="Index"><i class="bi bi-skip-backward-fill"></i> Back to List</a>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
