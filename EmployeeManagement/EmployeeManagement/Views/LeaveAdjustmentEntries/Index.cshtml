@model IEnumerable<EmployeeManagement.Models.LeaveAdjustmentEntry>

@{
    ViewData["Title"] = "Leave Adjustments";
    var totalAdjustments = Model.Count();

    var positiveCount = Model.Count(x =>
        x.AdjustmentType.Description.Trim().ToLower() == "positive");

    var negativeCount = Model.Count(x =>
        x.AdjustmentType.Description.Trim().ToLower() == "negative");
}
<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-weight:600;color:#2d3748;">
            <i class="bx bx-calendar-check mr-2" style="color:#667eea;"></i>
            Leave Adjustments
        </h2>
        <p class="text-muted mb-0">
            Manage employee leave adjustments
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary"
       style="border-radius:10px;padding:12px 24px;font-weight:500;">
        <i class="bx bx-plus mr-2"></i>Add Adjustment
    </a>
</div>

<!-- Statistics Card -->
<div class="row mb-4">

    <!-- Total -->
    <div class="col-lg-4 col-md-6 mb-3">
        <div class="card stats-card"
             style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1">Total Adjustments</p>
                        <h3>@totalAdjustments</h3>
                    </div>
                    <div class="employee-avatar" style="background:rgba(255,255,255,.2);">
                        <i class="bx bx-calendar-check"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Positive -->
    <div class="col-lg-4 col-md-6 mb-3">
        <div class="card stats-card"
             style="background:linear-gradient(135deg,#11998e 0%,#38ef7d 100%);color:white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1">Positive Adjustments</p>
                        <h3>@positiveCount</h3>
                    </div>
                    <div class="employee-avatar" style="background:rgba(255,255,255,.2);">
                        <i class="bx bx-up-arrow-alt"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Negative -->
    <div class="col-lg-4 col-md-6 mb-3">
        <div class="card stats-card"
             style="background:linear-gradient(135deg,#ff6b6b 0%,#ee5253 100%);color:white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1">Negative Adjustments</p>
                        <h3>@negativeCount</h3>
                    </div>
                    <div class="employee-avatar" style="background:rgba(255,255,255,.2);">
                        <i class="bx bx-down-arrow-alt"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>


<!-- Main Content -->
<div class="card main-card">
    <div class="card-body p-0">
        <div class="p-4 border-bottom" style="background:#fafbfc;">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white border-right-0"
                                  style="border-radius:10px 0 0 10px;">
                                <i class="bx bx-search text-muted"></i>
                            </span>
                        </div>

                        <input type="text"
                               id="searchBox"
                               class="form-control border-left-0 search-box"
                               placeholder="Search adjustments..."
                               style="border-radius:0 10px 10px 0;">
                    </div>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="table-responsive">
            <table id="example1" class="table table-striped table-hover">
                <thead class="table-header">
                    <tr>
                        <th><i class='bx bx-user'></i> Employee</th>
                        <th><i class='bx bx-calendar'></i> Adjustment Date</th>
                        <th><i class='bx bx-time'></i> Days</th>
                        <th><i class='bx bx-detail'></i> Description</th>
                        <th><i class='bx bx-category'></i> Type</th>
                        <th class="text-center"><i class='bx bx-cog'></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="employee-avatar mr-3" style="background:#667eea;">
                                        @item.Employee.FullName.Substring(0, 1)
                                    </div>
                                    <div>
                                        <span style="font-weight:600;color:#2d3748;">
                                            @item.Employee.FullName
                                        </span>
                                    </div>
                                </div>
                            </td>
                            <td>@item.LeaveAdjustmentDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (item.AdjustmentType.Description.ToLower() == "negative")
                                {
                                    <span class="status-badge status-rejected">
                                        -@item.NoOfDays days
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-approved">
                                        +@item.NoOfDays days
                                    </span>
                                }
                            </td>
                            <td>@item.AdjustmentDescription</td>
                            <td>
                                <span class="status-badge @(item.AdjustmentType.Description.Trim().ToLower() == "negative"
                                              ? "status-rejected"
                                              : "status-approved")">
                                @item.AdjustmentType.Description
                            </span>
                        </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info action-btn" title="View Details">
                                        <i class='bx bx-show'></i>
                                    </a>

                                    <a asp-action="Edit"  asp-route-id="@item.Id" class="btn btn-outline-primary action-btn" title="Edit">
                                        <i class='bx bx-edit'></i>
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger action-btn" title="Delete">
                                        <i class='bx bx-trash'></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="p-3 border-top" style="background:#fafbfc;">
            <small class="text-muted">
                Showing <strong>@Model.Count()</strong> adjustment(s)
            </small>
        </div>
    </div>
</div>
