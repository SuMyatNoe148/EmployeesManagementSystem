@model IEnumerable<EmployeeManagement.Models.LeaveApplication>

@{
    ViewData["Title"] = "Leave Application Management";
    var totalCount = Model?.Count() ?? 0;
    var approvedCount = Model?.Count(x => x.Status?.Code == "Approved") ?? 0;
    var pendingCount = Model?.Count(x => x.Status?.Code == "AwaitingApproval") ?? 0;
    var rejectedCount = Model?.Count(x => x.Status?.Code == "Rejected") ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-weight: 600; color: #2d3748;">
            <i class="bx bx-calendar-check mr-2" style="color: #667eea;"></i>Leave Application Management
        </h2>
        <p class="text-muted mb-0">Manage employee leave requests and approvals</p>
    </div>
    <a asp-action="Create" class="btn btn-primary" style="border-radius: 10px; padding: 12px 24px; font-weight: 500;">
        <i class="bi bi-plus-lg mr-2"></i>New Application
    </a>
</div>

<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card stats-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1" style="opacity: 0.9; font-size: 14px;">Total Applications</p>
                        <h3 class="mb-0" style="font-size: 28px; font-weight: 700;">@totalCount</h3>
                    </div>
                    <div style="background: rgba(255,255,255,0.2); width: 50px; height: 50px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                        <i class="bx bx-calendar-check" style="font-size: 24px;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card stats-card" style="background: linear-gradient(135deg, #10b981 0%, #34d399 100%); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1" style="opacity: 0.9; font-size: 14px;">Approved</p>
                        <h3 class="mb-0" style="font-size: 28px; font-weight: 700;">@approvedCount</h3>
                    </div>
                    <div style="background: rgba(255,255,255,0.2); width: 50px; height: 50px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                        <i class="bx bx-check-circle" style="font-size: 24px;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card stats-card" style="background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1" style="opacity: 0.9; font-size: 14px;">Pending</p>
                        <h3 class="mb-0" style="font-size: 28px; font-weight: 700;">@pendingCount</h3>
                    </div>
                    <div style="background: rgba(255,255,255,0.2); width: 50px; height: 50px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                        <i class="bx bx-time" style="font-size: 24px;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-3">
        <div class="card stats-card" style="background: linear-gradient(135deg, #ef4444 0%, #f87171 100%); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1" style="opacity: 0.9; font-size: 14px;">Rejected</p>
                        <h3 class="mb-0" style="font-size: 28px; font-weight: 700;">@rejectedCount</h3>
                    </div>
                    <div style="background: rgba(255,255,255,0.2); width: 50px; height: 50px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                        <i class="bx bx-x-circle" style="font-size: 24px;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card main-card">
    <div class="card-body p-0">
        <div class="p-4 border-bottom" style="background: #fafbfc;">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white border-right-0" style="border-radius: 10px 0 0 10px;"><i class="bx bx-search text-muted"></i></span>
                        </div>
                        <input type="text" id="searchBox" class="form-control border-left-0 search-box" placeholder="Search by employee, leave type or status..." style="border-radius: 0 10px 10px 0;">
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table id="dataTable" class="table table-hover mb-0" style="font-size: 14px;">
                <thead class="table-header">
                    <tr>
                        <th style="width: 60px;"></th>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Duration</th>
                        <th class="text-center">Status</th>
                        <th class="text-center" style="width: 180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.Any() != true)
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <div style="width: 80px; height: 80px; background: #f3f4f6; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                                        <i class="bx bx-calendar-check" style="font-size: 36px; color: #9ca3af;"></i>
                                    </div>
                                    <h5 class="text-muted mb-2">No Leave Applications Found</h5>
                                    <a asp-action="Create" class="btn btn-primary" style="border-radius: 8px;"><i class="bi bi-plus-lg mr-2"></i>New Application</a>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            var bgColors = new[] { "#667eea", "#764ba2", "#11998e", "#38ef7d", "#f093fb", "#f5576c" };
                            var bgColor = bgColors[Math.Abs(item.Id.GetHashCode()) % bgColors.Length];
                            var statusClass = item.Status?.Code switch { "Approved" => "status-approved", "Rejected" => "status-rejected", _ => "status-pending" };
                            <tr class="data-row">
                                <td class="text-center"><div class="app-icon" style="background: @bgColor;"><i class="bx bx-calendar"></i></div></td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span style="font-weight: 600; color: #2d3748; font-size: 15px;">@item.Employee?.FullName</span>
                                        <small class="text-muted"><i class="bx bx-time mr-1"></i>@item.StartDate.ToString("yyyy-MM-dd") - @item.EndDate.ToString("yyyy-MM-dd")</small>
                                    </div>
                                </td>
                                <td><span class="text-muted">@item.LeaveType?.Name</span></td>
                                <td><span class="days-badge">@item.NoOfDays days</span></td>
                                <td class="text-center"><span class="status-badge @statusClass">@item.Status?.Description</span></td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary action-btn" data-toggle="tooltip" title="Edit"><i class="bx bx-edit"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info action-btn" data-toggle="tooltip" title="View"><i class="bx bx-show"></i></a>
                                        @if (item.Status?.Code == "AwaitingApproval")
                                        {
                                            <a asp-action="ApproveLeave" asp-route-id="@item.Id" class="btn btn-outline-success action-btn" data-toggle="tooltip" title="Approve"><i class="bx bx-check"></i></a>
                                            <a asp-action="RejectLeave" asp-route-id="@item.Id" class="btn btn-outline-danger action-btn" data-toggle="tooltip" title="Reject"><i class="bx bx-x"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (totalCount > 0)
        {
            <div class="p-3 border-top" style="background: #fafbfc;">
                <small class="text-muted">Showing <strong>@totalCount</strong> application@(totalCount != 1 ? "s" : "")</small>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('[data-toggle="tooltip"]').tooltip();
            $('#searchBox').on('keyup', function() {
                var value = $(this).val().toLowerCase();
                $('.data-row').filter(function() { $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1) });
            });
        });
    </script>
}
