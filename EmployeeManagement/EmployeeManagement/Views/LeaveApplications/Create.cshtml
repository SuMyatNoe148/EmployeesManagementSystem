@model EmployeeManagement.Models.LeaveApplication

@{
    ViewData["Title"] = "Create";
}
<div class="card">
    <div class="card-header">
        <h3 class="card-title"> New Leave Application</h3>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-12">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="EmployeeId" class="control-label"></label>
                                <select asp-for="EmployeeId" class="form-control" asp-items="ViewBag.EmployeeId"></select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="NoOfDays" class="control-label"></label>
                                <input asp-for="NoOfDays" type="number" class="form-control" />
                                <span asp-validation-for="NoOfDays" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="StartDate" class="control-label"></label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="DurationId" class="control-label"></label>
                                <select asp-for="DurationId" class="form-control" asp-items="ViewBag.DurationId"></select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="LeaveTypeId" class="control-label"></label>
                                <select asp-for="LeaveTypeId" class="form-control" asp-items="ViewBag.LeaveTypeId"></select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Attachment" class="control-label"></label>
                                <input class="form-control" type="file" id="photo" name="leaveattachment" />
                                <span asp-validation-for="Attachment" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Description" class="control-label"></label>
                                <input asp-for="Description" class="form-control" />
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group p-lg-5">
                        <div class="col-md-12">
                            <a asp-action="Index" class="btn btn-warning float-left"><i class="bi bi-skip-backward-fill"></i> Back To List</a>
                            <button type="submit"  class="btn btn-primary float-right"><i class="bi bi-save2"></i> Save Leave Application</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
     </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
