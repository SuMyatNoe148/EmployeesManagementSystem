@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h2 class="page-title"><i class="bx bxs-dashboard mr-2" style="color: #667eea;"></i>Dashboard Overview</h2>
    <p class="page-subtitle">Welcome to Employee Management System - Here's your system overview</p>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="stat-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <div class="icon-bg"><i class="bx bx-user"></i></div>
            <h3>150</h3>
            <p><i class="bx bx-user mr-1"></i>Total Employees</p>
            <div class="stat-footer">
                <a asp-controller="Employees" asp-action="Index"><span>View All</span>
                <i class="bx bx-right-arrow-alt"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="stat-card" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
            <div class="icon-bg"><i class="bx bx-building"></i></div>
            <h3>53<sup style="font-size: 18px">%</sup></h3>
            <p><i class="bx bx-building mr-1"></i>Total Clients</p>
            <div class="stat-footer">
                <a asp-controller="Clients" asp-action="Index"><span>View All</span>
                <i class="bx bx-right-arrow-alt"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="stat-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
            <div class="icon-bg"><i class="bx bx-calendar-check"></i></div>
            <h3>44</h3>
            <p><i class="bx bx-calendar-check mr-1"></i>Leave Applications</p>
            <div class="stat-footer">
                <a asp-controller="LeaveApplications" asp-action="Index"><span>View All</span>
                <i class="bx bx-right-arrow-alt"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="stat-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
            <div class="icon-bg"><i class="bx bx-briefcase"></i></div>
            <h3>65</h3>
            <p><i class="bx bx-briefcase mr-1"></i>Total Assets</p>
            <div class="stat-footer">
                <a asp-controller="FixedAssets" asp-action="Index"><span>View All</span>
                <i class="bx bx-right-arrow-alt"></i>
                </a>
            </div>
        </div>
    </div>
</div>
