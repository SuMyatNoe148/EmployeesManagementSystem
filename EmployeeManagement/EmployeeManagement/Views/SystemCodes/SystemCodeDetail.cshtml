@model IEnumerable<EmployeeManagement.Models.SystemCodeDetail>

@{
    ViewData["Title"] = "Index";
}

<p>
    <a asp-action="Create" asp-controller="SystemCodeDetails" class="btn btn-primary"><i class="bi bi-plus-square"></i> Add New System Code Detail</a>
</p>
<div class="card">
    <div class="card-header">
        <h3 class="card-title">System Code Detail Lists</h3>
    </div>
    <!-- /.card-header -->
    <div class="card-body">
        <table id="example1" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.SystemCode)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Code)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Description)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.OrderNo)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.CreatedById)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.CreatedOn)
                    </th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.SystemCode.Description)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Code)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Description)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.OrderNo)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.CreatedBy.FullName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.CreatedOn)
                        </td>
                        <td>
                            <div class="ms-auto">
                                <div class="btn-group">
                                    <button type="button" class="btn btn-primary"> Actions</button>
                                    <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-toggle="dropdown" aria-expanded="false">
                                        <span class="visually-hidden"></span>
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-right dropdown-menu-lg-end">
                                        <a asp-action="Edit" asp-controller="SystemCodeDetails" asp-route-id="@item.Id" class="dropdown-item">
                                            <i class="bx bxs-edit"></i> Edit
                                        </a>
                                        <div class="dropdown-divider"></div>
                                        <a asp-action="Details" asp-controller="SystemCodeDetails" asp-route-id="@item.Id" class="dropdown-item">
                                            <i class="bx bxs-show"></i> View
                                        </a>
                                        <div class="dropdown-divider"></div>
                                        <a asp-action="Delete" asp-controller="SystemCodeDetails" asp-route-id="@item.Id" class="dropdown-item">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </td>
                       
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

