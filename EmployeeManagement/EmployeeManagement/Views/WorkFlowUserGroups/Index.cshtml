@model IEnumerable<EmployeeManagement.Models.WorkFlowUserGroup>

@{
    ViewData["Title"] = "Workflow User Groups";
    var totalCount = Model?.Count() ?? 0;
}
<!--Header-->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-weight:600;color:#2d3748;">
            <i class="bx bx-group mr-2" style="color:#667eea;"></i>
            Workflow User Groups
        </h2>
        <p class="text-muted mb-0">
            Manage workflow approval groups and departments
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary"
       style="border-radius:10px;padding:12px 24px;font-weight:500;">
        <i class="bx bx-plus mr-2"></i>Add Group
    </a>
</div>

<!-- Statistics Cards -->
<div class="row mb-4">
    <div class="col-lg-4 col-md-6 mb-3">
        <div class="card stats-card"
             style="background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1" style="opacity:.9;font-size:14px;">
                            Total Groups
                        </p>

                        <h3 class="mb-0"
                            style="font-size:32px;font-weight:700;">
                            @totalCount
                        </h3>
                    </div>

                    <div style="background:rgba(255,255,255,.2);
                                width:60px;
                                height:60px;
                                border-radius:12px;
                                display:flex;
                                align-items:center;
                                justify-content:center;">
                        <i class="bx bx-group"
                           style="font-size:28px;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!--Toolbar-->
<div class="p-4 border-bottom" style="background:#fafbfc;">
    <div class="row align-items-center">
        <div class="col-md-6">
            <div class="input-group">
                <div class="input-group-prepend">
                    <span class="input-group-text bg-white border-right-0"
                          style="border-radius:10px 0 0 10px;">
                        <i class="bx bx-search text-muted"></i>
                    </span>
                </div>

                <input type="text"
                       id="searchBox"
                       class="form-control border-left-0 search-box"
                       placeholder="Search groups..."
                       style="border-radius:0 10px 10px 0;">
            </div>
        </div>
    </div>
</div>
                <<div class="table-responsive">
    <table id="dataTable" class="table table-hover mb-0" style="font-size: 14px;">
        <thead class="table-header">
            <tr>
                <th><i class='bx bx-code'></i> Code</th>
                <th><i class='bx bx-file'></i> Document Type</th>
                <th><i class='bx bx-building'></i> Department</th>
                <th><i class='bx bx-detail'></i> Description</th>
                <th class="text-center"><i class='bx bx-cog'></i> Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <span class="badge badge-primary">@item.Code</span>
                    </td>
                    <td>@item.DocumentType.Description</td>
                    <td>
                        <span class="badge badge-secondary">
                            <i class='bx bx-building'></i> @item.Department.Name
                        </span>
                    </td>
                    <td>@item.Description</td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary action-btn" data-toggle="tooltip"
                               title="Edit">
                                <i class="bx bx-edit"></i>
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger action-btn" data-toggle="tooltip"
                               title="Delete">
                                <i class="bx bx-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (totalCount > 0)
{
    <div class="p-3 border-top" style="background:#fafbfc;">
        <small class="text-muted">
            Showing <strong>@totalCount</strong> group@(totalCount != 1 ? "s" : "")
        </small>
    </div>
}


@section Scripts {
    <script>
        $(function () {

            $('[data-toggle="tooltip"]').tooltip();

            $('#searchBox').on('keyup', function () {

                var value = $(this).val().toLowerCase();

                $('.data-row').filter(function () {
                    $(this).toggle(
                        $(this).text().toLowerCase().indexOf(value) > -1
                    );
                });

            });

        });
    </script>
}