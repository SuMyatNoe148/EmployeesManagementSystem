@model EmployeeManagement.Models.SystemProfile

@{
    ViewData["Title"] = "System Profile";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Add New System Profile</h3>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-12">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Name" class="control-label"></label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">

                            <div class="form-group">
                                <label asp-for="ProfileId" class="control-label"></label>
                                <select asp-for="ProfileId" class="form-control" asp-items="ViewBag.ProfileId">
                                    <option value="">Select System Profile</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Order" class="control-label"></label>
                                <input asp-for="Order" class="form-control" />
                                <span asp-validation-for="Order" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group p-lg-5">
                        <div class="col-md-12">
                            <a asp-action="Index" class="btn btn-warning float-left"><i class="bi bi-skip-backward-fill"></i> Back To List</a>
                            <button type="submit" class="btn btn-primary float-right"><i class="bi bi-save2"></i> Save System Profile</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

