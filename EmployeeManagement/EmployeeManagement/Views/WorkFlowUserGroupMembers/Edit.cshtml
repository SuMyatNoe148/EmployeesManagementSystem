@model EmployeeManagement.Models.WorkFlowUserGroupMember

@{
    ViewData["Title"] = "Edit";
}
<div class="row">
    <div class="col-xl-12 mx-auto">
        <div class="card border-top border-0 border-4 border-info">
            <div class="card-body">
                <div class="border p-4 rounded">
                    <div class="card-title d-flex align-items-center">
                        <div>
                            <i class="bx bxs-user me-1 font-22 text-info"></i>
                        </div>
                        <h5 class="mb-0 text-info">Update Workflow User Group Member</h5>
                    </div>
                    <hr />
                    <div class="row g-3">
                        <div class="col-md-12">
                            <form asp-action="Edit">
                                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                <input type="hidden" asp-for="Id" />
                                <div class="form-group">
                                    <label asp-for="WorkFlowUserGroupId" class="control-label"></label>
                                    <select asp-for="WorkFlowUserGroupId" class="form-control" asp-items="ViewBag.WorkFlowUserGroupId"></select>
                                    <span asp-validation-for="WorkFlowUserGroupId" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="SenderId" class="control-label"></label>
                                    <select asp-for="SenderId" class="form-control" asp-items="ViewBag.SenderId"></select>
                                    <span asp-validation-for="SenderId" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="ApproverId" class="control-label"></label>
                                    <select asp-for="ApproverId" class="form-control" asp-items="ViewBag.ApproverId"></select>
                                    <span asp-validation-for="ApproverId" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label asp-for="SequenceNo" class="control-label"></label>
                                    <input asp-for="SequenceNo" class="form-control" />
                                    <span asp-validation-for="SequenceNo" class="text-danger"></span>
                                </div>
                                <div class="form-group p-lg-5">
                                    <div class="col-md-12">
                                        <a asp-action="Index" class="btn btn-warning float-left"><i class="bi bi-skip-backward-fill"></i> Back To List</a>
                                        <button type="submit" class="btn btn-primary float-right"><i class="bi bi-floppy-fill"></i> Update User Group</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
