@model IEnumerable<EmployeeManagement.Models.WorkFlowUserGroupMember>

@{
    ViewData["Title"] = "User Group Members";
}
<p>
    <a asp-action="Create" class="btn btn-primary float-end"><i class="bi bi-plus-square"></i>  Add New User Group Member</a>
</p>
<div class="card">
    <div class="card-header">
        <h3 class="card-title">WorkFlow User Groups Members List</h3>
    </div>
    <!-- /.card-header -->
    <div class="card-body">
        <table id="example1" class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.WorkFlowUserGroup)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Sender)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Approver)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.SequenceNo)
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @Html.DisplayFor(modelItem => item.WorkFlowUserGroup.Description)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Sender.FullName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Approver.FullName)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.SequenceNo)
                        </td>
                        <td>
                            <div class="ms-auto">
                                <div class="btn-group">
                                    <button type="button" class="btn btn-primary"> Actions</button>
                                    <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-toggle="dropdown" aria-expanded="false">
                                        <span class="visually-hidden"></span>
                                    </button>
                                    <div class="dropdown-menu dropdown-menu-right dropdown-menu-lg-end">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="dropdown-item">
                                            <i class="bx bxs-edit"></i> Edit
                                        </a>
                                        <div class="dropdown-divider"></div>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="dropdown-item">
                                            <i class="bx bxs-show"></i> View
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
