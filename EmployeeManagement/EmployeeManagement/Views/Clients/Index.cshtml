@model IEnumerable<EmployeeManagement.Models.Client>

@{
    ViewData["Title"] = "Clients Management";
    var totalCount = Model?.Count() ?? 0;
}

<div class="content-wrapper">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1 class="m-0 text-dark"><i class='bx bx-briefcase-alt'></i> Clients Management</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item active">Clients</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <!-- Statistics Card -->
            <div class="row mb-4">
                <div class="col-lg-4 col-md-6 mb-3">
                    <div class="card stats-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <p class="mb-1" style="opacity: 0.9; font-size: 14px;">Total Clients</p>
                                    <h3 class="mb-0" style="font-size: 32px; font-weight: 700;">@totalCount</h3>
                                </div>
                                <div style="background: rgba(255,255,255,0.2); width: 60px; height: 60px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                    <i class="bx bx-briefcase-alt" style="font-size: 28px;"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-outline card-primary">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class='bx bx-list-ul'></i> Client List
                    </h3>
                    <div class="card-tools">
                        <a asp-action="Create" class="btn btn-success btn-sm">
                            <i class='bx bx-plus'></i> Add New Client
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table id="example1" class="table table-striped table-hover">
                        <thead class="thead-light">
                            <tr>
                                <th><i class='bx bx-code'></i> Code</th>
                                <th><i class='bx bx-buildings'></i> Client Name</th>
                                <th><i class='bx bx-map'></i> Address</th>
                                <th><i class='bx bx-phone'></i> Phone</th>
                                <th><i class='bx bx-envelope'></i> Email</th>
                                <th><i class='bx bx-check-circle'></i> Status</th>
                                <th class="text-center"><i class='bx bx-cog'></i> Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var statusClass = item.Status?.Description?.ToLower() switch
                                {
                                    "active" => "badge-success",
                                    "inactive" => "badge-secondary",
                                    _ => "badge-light"
                                };
                                <tr>
                                    <td><span class="badge badge-primary">@item.Code</span></td>
                                    <td>
                                        <span style="font-weight: 600; color: #2d3748;">@item.Name</span>
                                    </td>
                                    <td>@item.Address</td>
                                    <td>
                                        <span class="badge badge-light">
                                            <i class='bx bx-phone-call'></i> @item.PhoneNumber
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-muted"><i class='bx bx-envelope mr-1'></i>@item.Email</span>
                                    </td>
                                    <td>
                                        <span class="badge @statusClass">@item.Status?.Description</span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm" title="View Details">
                                                <i class='bx bx-show'></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Edit">
                                                <i class='bx bx-edit'></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" title="Delete">
                                                <i class='bx bx-trash'></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer">
                    <small class="text-muted"><i class='bx bx-info-circle'></i> Total Records: @Model.Count()</small>
                </div>
            </div>
        </div>
    </section>
</div>



