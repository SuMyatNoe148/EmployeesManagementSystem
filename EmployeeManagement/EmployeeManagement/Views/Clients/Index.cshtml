@model IEnumerable<EmployeeManagement.Models.Client>

@{
    ViewData["Title"] = "Clients Management";
    var totalCount = Model?.Count() ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1" style="font-weight:600;color:#2d3748;">
            <i class="bx bx-briefcase-alt mr-2" style="color:#667eea;"></i>
            Clients Management
        </h2>
        <p class="text-muted mb-0">
            Manage company clients and records
        </p>
    </div>

    <a asp-action="Create"
       class="btn btn-primary"
       style="border-radius:10px;padding:12px 24px;font-weight:500;">
        <i class="bx bx-plus mr-2"></i>Add Client
    </a>
</div>
<!-- Statistics Card -->
<div class="row mb-4">
    <div class="col-lg-4 col-md-6 mb-3">
        <div class="card stats-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="mb-1" style="opacity: 0.9; font-size: 14px;">Total Clients</p>
                        <h3 class="mb-0" style="font-size: 32px; font-weight: 700;">@totalCount</h3>
                    </div>
                    <div style="background: rgba(255,255,255,0.2); width: 60px; height: 60px; border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                        <i class="bx bx-briefcase-alt" style="font-size: 28px;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card main-card">
    <div class="p-4 border-bottom" style="background:#fafbfc;">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-white border-right-0"
                              style="border-radius:10px 0 0 10px;">
                            <i class="bx bx-search text-muted"></i>
                        </span>
                    </div>

                    <input type="text"
                           id="searchBox"
                           class="form-control border-left-0 search-box"
                           placeholder="Search clients..."
                           style="border-radius:0 10px 10px 0;">
                </div>
            </div>
        </div>
    </div>
    <div class="table-responsive">
        <table id="dataTable" class="table table-hover mb-0" style="font-size: 14px;">
            <thead class="table-header">
                <tr>
                    <th><i class='bx bx-code'></i> Code</th>
                    <th><i class='bx bx-buildings'></i> Client Name</th>
                    <th><i class='bx bx-map'></i> Address</th>
                    <th><i class='bx bx-phone'></i> Phone</th>
                    <th><i class='bx bx-envelope'></i> Email</th>
                    <th><i class='bx bx-check-circle'></i> Status</th>
                    <th class="text-center"><i class='bx bx-cog'></i> Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var statusClass = item.Status?.Description?.ToLower() switch
                    {
                        "active" => "badge-success",
                        "inactive" => "badge-secondary",
                        _ => "badge-light"
                    };
                    <tr>
                        <td><span class="badge badge-primary">@item.Code</span></td>
                        <td>
                            <span style="font-weight: 600; color: #2d3748;">@item.Name</span>
                        </td>
                        <td>@item.Address</td>
                        <td>
                            <span class="badge badge-light">
                                <i class='bx bx-phone-call'></i> @item.PhoneNumber
                            </span>
                        </td>
                        <td>
                            <span class="text-muted"><i class='bx bx-envelope mr-1'></i>@item.Email</span>
                        </td>
                        <td>
                            <span class="badge @statusClass">@item.Status?.Description</span>
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-info action-btn"
                                   title="View">
                                    <i class="bx bx-show"></i>
                                </a>

                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary action-btn"
                                   title="Edit">
                                    <i class="bx bx-edit"></i>
                                </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (totalCount > 0)
    {
        <div class="p-3 border-top" style="background:#fafbfc;">
            <small class="text-muted">
                Showing <strong>@totalCount</strong> client@(totalCount != 1 ? "s" : "")
            </small>
        </div>
    }
</div>


