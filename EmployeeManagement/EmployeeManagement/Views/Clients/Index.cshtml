@model IEnumerable<EmployeeManagement.Models.Client>



@{

    ViewData["Title"] = "Clients List";

}



<div class="card">

    <div class="card-header">

        <div class="mb-3 float-right">

            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-square"></i> Add New Client</a>

        </div>

    </div>

    <!-- /.card-header -->

    <div class="card-body">

        <table id="example1" class="table table-bordered table-striped">

            <thead>

                <tr>

                    <th>

                        @Html.DisplayNameFor(model => model.Code)

                    </th>

                    <th>

                        @Html.DisplayNameFor(model => model.Name)

                    </th>

                    <th>

                        @Html.DisplayNameFor(model => model.Address)

                    </th>

                    <th>

                        @Html.DisplayNameFor(model => model.PhoneNumber)

                    </th>

                    <th>

                        @Html.DisplayNameFor(model => model.Email)

                    </th>

                    <th>

                        @Html.DisplayNameFor(model => model.Status)

                    </th>

                    <th>Edit</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in Model)

                {

                    <tr>

                        <td>

                            @Html.DisplayFor(model => item.Code)

                        </td>

                        <td>

                            @Html.DisplayFor(model => item.Name)

                        </td>

                        <td>

                            @Html.DisplayFor(model => item.Address)

                        </td>

                        <td>

                            @Html.DisplayFor(model => item.PhoneNumber)

                        </td>

                        <td>

                            @Html.DisplayFor(model => item.Email)

                        </td>

                        <td>

                            <span class="btn btn-outline-success btn-smpx-4 rounded-3 w-100"> @Html.DisplayFor(model => item.Status.Description)</span>

                        </td>

                        <td>

                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm"><i class="bx bxs-edit"></i></a>

                        </td>

                    </tr>

                }

            </tbody>

        </table>

    </div>

</div>



